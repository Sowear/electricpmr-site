---
import Layout from '@/layouts/Layout.astro';
import PageComponent from '@/pages/Contact';
import PageWrapper from '@/components/PageWrapper';

const title = "Контакты электрика в Тирасполе и ПМР | ЭлектроМастер";
const description = "Контакты для заказа электромонтажных работ в Тирасполе и ПМР. Консультация, расчёт стоимости и запись на выезд специалиста.";
---

<Layout title={title} description={description}>
  <PageWrapper pagePath="Contact" currentPath={Astro.url.pathname} client:load />
</Layout>
