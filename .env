# Backend: Cloudflare Worker (D1). Setting VITE_API_BASE_URL routes the whole
# app through the Cloudflare worker instead of Supabase.
#  - local dev:  http://127.0.0.1:8787  (started via `wrangler dev`)
#  - production: your deployed worker URL, e.g. https://electricpmr.<account>.workers.dev
VITE_API_BASE_URL=http://127.0.0.1:8787
