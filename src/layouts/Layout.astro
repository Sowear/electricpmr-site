    <!-- FAQPage Schema for Rich Snippets -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Сколько стоит электромонтаж?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Стоимость зависит от объёма работ, состояния проводки и сложности проекта. Мы сначала уточняем задачу и даём понятный расчёт без скрытых доплат."
          }
        },
        {
          "@type": "Question",
          "name": "Вы работаете только в Тирасполе?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Работаем в Тирасполе, Слободзее, Бендерах, Днестровске и Григориополе. Выезд в другие населённые пункты — по договорённости."
          }
        },
        {
          "@type": "Question",
