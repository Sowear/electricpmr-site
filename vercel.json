{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/features", "destination": "/uslugi", "statusCode": 301 },
    { "source": "/pricing", "destination": "/stoimost", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/|sitemap\\.xml|robots\\.txt|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
