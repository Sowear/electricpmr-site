          }
        },
        {
          "@type": "Question",
          "name": "Можно ли сначала проконсультироваться?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Да, вы можете написать нам или отправить фото/видео задачи. Подскажем решение и сориентируем по стоимости."
          }
        },
        {
          "@type": "Question",
          "name": "Вы работаете с частными домами и квартирами?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Да, выполняем электромонтаж в квартирах, частных домах, новостройках и коммерческих помещениях."
          }
        }
      ]
    }
    </script>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: title,
      description: description,
      url: canonicalUrl,
      inLanguage: "ru"
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: breadcrumbItems,
    })} />
  </head>
  <body>
    <div id="root">
      <slot />
    </div>
  </body>
</html>
